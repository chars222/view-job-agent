---
// Importamos los estilos globales de Tailwind
import '../styles/global.css';
---
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI Job Agent - Portafolio</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style is:global>
        /* Estilos para el grafo interactivo */
        .node-btn { transition: all 0.2s ease; }
        .node-btn:hover { transform: translateY(-2px); box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1); }
        .node-btn.active { 
            border-color: #3b82f6; 
            background-color: #eff6ff;
            box-shadow: 0 0 0 2px rgba(59, 130, 246, 0.5);
        }
        .node-btn.active .icon-bg { background-color: #3b82f6; color: white; }
        
        /* Scrollbars elegantes */
        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: #f1f1f1; border-radius: 4px; }
        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
        
        .fade-in { animation: fadeIn 0.3s ease-in-out; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(5px); } to { opacity: 1; transform: translateY(0); } }
    </style>
</head>
<body class="bg-gray-50 text-gray-800 font-sans h-screen flex flex-col overflow-hidden">

    <!-- Header Portafolio -->
    <header class="bg-slate-900 text-white px-6 py-4 flex justify-between items-center shrink-0 shadow-md z-10">
        <div>
            <h1 class="text-2xl font-bold flex items-center gap-2">
                <i class="fa-solid fa-network-wired text-blue-400"></i> AI Multi-Agent Architecture
            </h1>
            <p class="text-slate-400 text-sm mt-1">Demostración Interactiva del Sistema de Búsqueda de Empleo Autónomo</p>
        </div>
        <div class="flex items-center gap-4">
            <div class="flex gap-3">
                <a href="https://github.com/chars222/job-agent.git" class="text-slate-300 hover:text-white transition"><i class="fa-brands fa-github text-xl"></i></a>
                <a href="https://www.linkedin.com/in/carlos-gutierrez-caballero-1934a2174/" class="text-slate-300 hover:text-white transition"><i class="fa-brands fa-linkedin text-xl"></i></a>
            </div>
        </div>
    </header>

    <!-- Contenedor Principal (3 Columnas) -->
    <main class="flex-grow flex overflow-hidden">
        
        <!-- Columna 1: Historial de Ejecuciones (Runs) -->
        <aside class="w-80 bg-white border-r border-gray-200 flex flex-col h-full shrink-0">
            <div class="p-4 border-b border-gray-200 bg-gray-50 flex justify-between items-center">
                <h2 class="font-bold text-gray-700 uppercase tracking-wider text-xs flex items-center gap-2">
                    <i class="fa-solid fa-database text-blue-500"></i> Historial de Ejecuciones
                </h2>
                <button onclick="fetchRuns()" title="Actualizar datos" class="text-gray-500 hover:text-blue-500 transition">
                    <i class="fa-solid fa-arrows-rotate text-sm"></i>
                </button>
            </div>
            <!-- Contenedor de la lista con scroll independiente -->
            <div id="runs-list" class="overflow-y-auto flex-grow p-2 space-y-2">
                <!-- Indicador de Carga inicial -->
                <div class="text-center py-8 text-gray-400" id="runs-loader">
                    <i class="fa-solid fa-circle-notch fa-spin text-2xl mb-2 text-blue-500"></i>
                    <p class="text-xs">Cargando ejecuciones...</p>
                </div>
            </div>
        </aside>

        <!-- Columna 2: Grafo Interactivo -->
        <section class="flex-grow bg-slate-50 flex flex-col relative overflow-y-auto">
            <!-- Banner informativo en caso de fallo de conexión de la API local o remota -->
            <div id="connection-warning" class="hidden bg-amber-50 border-b border-amber-200 text-amber-800 text-xs px-4 py-2 flex justify-between items-center shrink-0">
                <span class="flex items-center gap-2">
                    <i class="fa-solid fa-triangle-exclamation text-amber-500"></i>
                    No se pudo conectar con el servidor API (<span id="warn-url-text">/api/runs</span>). Se están mostrando datos simulados.
                </span>
                <button onclick="fetchRuns()" class="underline font-bold hover:text-amber-950">Reintentar</button>
            </div>

            <div class="p-6">
                <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 max-w-2xl mx-auto">
                    <div class="text-center mb-8">
                        <h2 class="text-xl font-bold text-gray-800" id="current-run-title">Selecciona una ejecución</h2>
                        <p class="text-gray-500 text-sm mt-1">Haz clic en los nodos para ver el trabajo del agente en tiempo real.</p>
                    </div>

                    <!-- Diagrama de Nodos -->
                    <div class="flex flex-col items-center space-y-6 relative py-4">
                        
                        <!-- Línea conectora central de fondo -->
                        <div class="absolute top-0 bottom-0 left-1/2 w-0.5 bg-gray-200 -translate-x-1/2 z-0"></div>

                        <!-- Orchestrator -->
                        <button onclick="selectNode('orchestrator')" id="node-orchestrator" class="node-btn w-64 bg-white border border-gray-300 rounded-xl p-3 flex items-center gap-4 z-10 text-left">
                            <div class="icon-bg w-10 h-10 rounded-lg bg-indigo-100 text-indigo-600 flex items-center justify-center text-lg shrink-0">
                                <i class="fa-solid fa-microchip"></i>
                            </div>
                            <div>
                                <h3 class="font-bold text-gray-800 text-sm">Orchestrator</h3>
                                <p class="text-xs text-gray-500">Llama-3 LLM</p>
                            </div>
                        </button>

                        <!-- Scraper -->
                        <button onclick="selectNode('scraper')" id="node-scraper" class="node-btn w-64 bg-white border border-gray-300 rounded-xl p-3 flex items-center gap-4 z-10 text-left">
                            <div class="icon-bg w-10 h-10 rounded-lg bg-emerald-100 text-emerald-600 flex items-center justify-center text-lg shrink-0">
                                <i class="fa-solid fa-spider"></i>
                            </div>
                            <div>
                                <h3 class="font-bold text-gray-800 text-sm">Scraper</h3>
                                <p class="text-xs text-gray-500">Apify / APIs Externas</p>
                            </div>
                        </button>

                        <!-- Matcher -->
                        <button onclick="selectNode('matcher')" id="node-matcher" class="node-btn w-64 bg-white border border-gray-300 rounded-xl p-3 flex items-center gap-4 z-10 text-left">
                            <div class="icon-bg w-10 h-10 rounded-lg bg-amber-100 text-amber-600 flex items-center justify-center text-lg shrink-0">
                                <i class="fa-solid fa-scale-balanced"></i>
                            </div>
                            <div>
                                <h3 class="font-bold text-gray-800 text-sm">Semantic Matcher</h3>
                                <p class="text-xs text-gray-500">Embeddings + VectorDB</p>
                            </div>
                        </button>

                        <!-- Reviewer -->
                        <button onclick="selectNode('reviewer')" id="node-reviewer" class="node-btn w-64 bg-white border border-gray-300 rounded-xl p-3 flex items-center gap-4 z-10 text-left relative">
                            <div class="icon-bg w-10 h-10 rounded-lg bg-rose-100 text-rose-600 flex items-center justify-center text-lg shrink-0">
                                <i class="fa-solid fa-user-tie"></i>
                            </div>
                            <div>
                                <h3 class="font-bold text-gray-800 text-sm">Reviewer</h3>
                                <p class="text-xs text-gray-500">Validación de Negocio</p>
                            </div>
                            <!-- Flecha condicional visual -->
                            <div class="absolute -right-24 top-1/2 -translate-y-1/2 flex items-center hidden md:flex opacity-50">
                                <span class="text-[10px] uppercase font-bold text-gray-500 mr-1">Retry</span>
                                <i class="fa-solid fa-arrow-turn-up text-gray-400 text-xl"></i>
                            </div>
                        </button>

                        <!-- Notifier -->
                        <button onclick="selectNode('notifier')" id="node-notifier" class="node-btn w-64 bg-white border border-gray-300 rounded-xl p-3 flex items-center gap-4 z-10 text-left">
                            <div class="icon-bg w-10 h-10 rounded-lg bg-blue-100 text-blue-600 flex items-center justify-center text-lg shrink-0">
                                <i class="fa-solid fa-paper-plane"></i>
                            </div>
                            <div>
                                <h3 class="font-bold text-gray-800 text-sm">Notifier</h3>
                                <p class="text-xs text-gray-500">Resend & Supabase</p>
                            </div>
                        </button>

                    </div>
                </div>
            </div>
        </section>

        <!-- Columna 3: Detalles del Nodo y Resultados -->
        <aside class="w-[450px] bg-white border-l border-gray-200 flex flex-col h-full shrink-0">
            <!-- Cabecera del Panel -->
            <div class="p-5 border-b border-gray-200 bg-slate-900 text-white">
                <div class="flex items-center gap-3 mb-2">
                    <div id="panel-icon" class="w-8 h-8 rounded bg-slate-800 flex items-center justify-center text-lg">
                        <i class="fa-solid fa-robot"></i>
                    </div>
                    <h2 id="panel-title" class="text-lg font-bold">Inspector de Nodo</h2>
                </div>
                <div id="panel-role" class="text-xs text-slate-400 mt-1 italic">
                    Selecciona un nodo en el grafo para ver su comportamiento.
                </div>
            </div>

            <!-- Contenido Dinámico -->
            <div id="panel-content" class="overflow-y-auto flex-grow p-5 space-y-6 bg-slate-50 hidden fade-in">
                
                <!-- Herramientas -->
                <div>
                    <h4 class="text-xs font-bold text-gray-500 uppercase tracking-wider mb-2">Herramientas Utilizadas</h4>
                    <div id="panel-tools" class="flex flex-wrap gap-2">
                        <!-- Llenado por JS -->
                    </div>
                </div>

                <!-- Input / Acción -->
                <div>
                    <h4 class="text-xs font-bold text-gray-500 uppercase tracking-wider mb-2">Entrada / Prompt</h4>
                    <div class="bg-gray-800 rounded-lg p-3 overflow-x-auto border border-gray-700 shadow-inner">
                        <pre id="panel-input" class="text-xs font-mono text-emerald-400 whitespace-pre-wrap leading-relaxed"></pre>
                    </div>
                </div>

                <!-- Output / Resultado -->
                <div>
                    <h4 class="text-xs font-bold text-gray-500 uppercase tracking-wider mb-2 flex justify-between items-center">
                        <span>Resultado Final</span>
                        <span id="panel-metrics" class="bg-blue-100 text-blue-700 px-2 py-0.5 rounded text-[10px] font-bold"></span>
                    </h4>
                    <div class="bg-white rounded-lg p-4 border border-gray-200 shadow-sm text-sm text-gray-700">
                        <div id="panel-output" class="space-y-2">
                            <!-- Llenado por JS (puede ser HTML) -->
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Estado Vacío -->
            <div id="panel-empty" class="flex-grow flex flex-col items-center justify-center text-gray-400 p-8 text-center">
                <i class="fa-solid fa-hand-pointer text-4xl mb-4 opacity-50"></i>
                <p>Haz clic en un nodo del diagrama para inspeccionar su código, prompts y resultados.</p>
            </div>
        </aside>

    </main>

    <script is:inline>
        // Endpoint REST nativo y relativo en frameworks Fullstack como Astro o Next.js
        const API_URL = '/api/runs';

        // Datos locales de fallback para el desarrollo si el servidor FastAPI no está corriendo
        const FALLBACK_DATA = [
            {
                "id": "440cefda-8d82-4603-8b50-8175bb27fcc9",
                "session_id": "run-20260520-171039",
                "created_at": "2026-05-20T21:11:58.36183+00:00",
                "profile_name": "Carlos Alfredo Gutierrez Caballero",
                "status": "success",
                "stats_found": 54,
                "stats_validated": 6,
                "nodes_data": {
                    "matcher": {
                        "role": "Filtrar basura semántica y pre-seleccionar con IA.",
                        "input": "Calculando similitud contra 54 empleos extraídos de: <b>Linkedin (25), Himalayas (13), Remotive (12), Arbeitnow (4)</b>.",
                        "tools": ["Sentence Transformers", "Cosine Similarity", "Llama-3"],
                        "metric": "26.5s",
                        "output": "<b>Evaluación Semántica:</b> Pasaron a pre-selección 17 ofertas laborales."
                    },
                    "scraper": {
                        "role": "Navegar la web y extraer vacantes raw usando APIs.",
                        "input": "Ejecutando consultas asíncronas para: ['arquitectura de software', 'desarrollo de software', 'inteligencia artificial', 'sector bancario']",
                        "tools": ["Apify LinkedIn", "GetOnBoard", "Remotive"],
                        "metric": "30.3s",
                        "output": "<b>Total extraído:</b> 54 empleos brutos en 4 plataformas"
                    },
                    "notifier": {
                        "role": "Notificar al usuario y guardar el estado.",
                        "input": "Preparando payload de Email con las 6 vacantes finales.",
                        "tools": ["Resend API", "Supabase Database"],
                        "metric": "3.8s",
                        "output": "<b>Acciones Exitosas:</b><br/>Estado de Correo: Enviado Exitosamente."
                    },
                    "reviewer": {
                        "role": "Aplicar reglas estrictas de negocio del usuario.",
                        "input": "Cruzando información contra base de datos y eliminando perfiles Junior/Spam.",
                        "tools": ["Supabase (Historial)", "Python Rules"],
                        "metric": "3.8s",
                        "output": "<b>Reporte de Validación:</b><br/><span class='text-green-600'>✓ 6 empleos aprobados definitivos para aplicar.</span><ul class='text-xs mt-3 bg-white p-2 rounded border border-gray-200 max-h-32 overflow-y-auto'><li class='mt-1 mb-1'>🔗 <a href='https://es.linkedin.com/jobs/view/ai-ml-engineer-at-outrigo-4357413020' target='_blank' class='text-blue-500 hover:text-blue-700 underline'>AI/ML Engineer</a> <span class='text-gray-500'>en Outrigo</span></li><li class='mt-1 mb-1'>🔗 <a href='https://www.linkedin.com/jobs/view/ai-ml-engineer-at-air-apps-4416497933' target='_blank' class='text-blue-500 hover:text-blue-700 underline'>AI/ML Engineer</a> <span class='text-gray-500'>en Air Apps</span></li><li class='mt-1 mb-1'>🔗 <a href='https://es.linkedin.com/jobs/view/ai-ml-engineer-at-air-apps-4416604324' target='_blank' class='text-blue-500 hover:text-blue-700 underline'>AI/ML Engineer</a> <span class='text-gray-500'>en Air Apps</span></li><li class='mt-1 mb-1'>🔗 <a href='https://nl.linkedin.com/jobs/view/ai-ml-engineer-at-air-apps-4416406703' target='_blank' class='text-blue-500 hover:text-blue-700 underline'>AI/ML Engineer</a> <span class='text-gray-500'>en Air Apps</span></li><li class='mt-1 mb-1'>🔗 <a href='https://www.linkedin.com/jobs/view/ai-ml-engineer-at-globo-4408205004' target='_blank' class='text-blue-500 hover:text-blue-700 underline'>AI /ML Engineer</a> <span class='text-gray-500'>en GLOBO</span></li><li class='mt-1 mb-1'>🔗 <a href='https://es.linkedin.com/jobs/view/ai-ml-engineer-python-at-jobgether-4416108386' target='_blank' class='text-blue-500 hover:text-blue-700 underline'>AI/ML Engineer, Python</a> <span class='text-gray-500'>en Jobgether</span></li></ul>"
                    },
                    "orchestrator": {
                        "role": "Analizar el CV y crear el plan de búsqueda.",
                        "input": "CV cargado (Longitud de análisis: 4256 caracteres).",
                        "tools": ["Groq Llama-3-70b", "PyPDF2"],
                        "metric": "11.3s",
                        "output": "<b>Perfil Extraído:</b><br/>Nombre: Carlos Alfredo Gutierrez Caballero<br/>Rol: Arquitecto de Software, Ingeniero de Software, Desarrollador de Software<br/>Keywords: ['arquitectura de software', 'desarrollo de software', 'inteligencia artificial', 'sector bancario']"
                    }
                }
            }
        ];

        let activeRuns = [];
        let currentRunData = null;

        // Formatear fechasISO de Supabase de manera elegante
        function formatCreatedDate(isoString) {
            try {
                const date = new Date(isoString);
                const options = { day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' };
                return date.toLocaleDateString('es-ES', options);
            } catch (e) {
                return isoString;
            }
        }

        // Obtener datos del endpoint configurado
        async function fetchRuns() {
            const warningBanner = document.getElementById('connection-warning');
            const warnUrlText = document.getElementById('warn-url-text');
            const runsListContainer = document.getElementById('runs-list');
            
            // Mostrar spinner de carga
            runsListContainer.innerHTML = `
                <div class="text-center py-8 text-gray-400" id="runs-loader">
                    <i class="fa-solid fa-circle-notch fa-spin text-2xl mb-2 text-blue-500"></i>
                    <p class="text-xs">Consultando base de datos...</p>
                </div>
            `;

            try {
                const response = await fetch(API_URL);
                if (!response.ok) {
                    throw new Error(`HTTP error! status: ${response.status}`);
                }
                const data = await response.json();
                
                // Normalizar respuesta: si retorna un solo objeto, envolverlo en un array
                activeRuns = Array.isArray(data) ? data : [data];
                warningBanner.classList.add('hidden'); // Ocultar aviso de error
                renderRuns(activeRuns);
                
            } catch (error) {
                console.warn("Error al consumir la API, cargando fallback:", error);
                // Mostrar advertencia de modo offline/simulado
                warnUrlText.innerText = API_URL;
                warningBanner.classList.remove('hidden');
                activeRuns = FALLBACK_DATA;
                renderRuns(activeRuns);
            }
        }

        // Renderizar la lista de ejecuciones (Runs) en el panel izquierdo
        function renderRuns(runs) {
            const list = document.getElementById('runs-list');
            list.innerHTML = '';
            
            if (runs.length === 0) {
                list.innerHTML = `
                    <div class="text-center py-8 text-gray-400">
                        <i class="fa-solid fa-inbox text-2xl mb-2"></i>
                        <p class="text-xs">No se encontraron ejecuciones.</p>
                    </div>
                `;
                return;
            }

            runs.forEach((run, index) => {
                const btn = document.createElement('button');
                btn.className = `w-full text-left p-3 rounded-lg border transition-all ${index === 0 ? 'bg-blue-50 border-blue-200 shadow-sm' : 'bg-white border-gray-100 hover:bg-gray-50 hover:border-gray-300'}`;
                btn.onclick = () => loadRun(run, btn);
                
                const formattedDate = formatCreatedDate(run.created_at || run.session_id);
                const statusColor = run.status === 'success' ? 'bg-green-500' : 'bg-rose-500';

                btn.innerHTML = `
                    <div class="flex justify-between items-start mb-1">
                        <span class="text-[10px] font-bold text-gray-400 tracking-wider font-mono">${run.session_id || 'RUN'}</span>
                        <div class="flex items-center gap-1.5">
                            <span class="text-[10px] text-gray-500 font-semibold">${formattedDate}</span>
                            <span class="w-2.5 h-2.5 rounded-full ${statusColor}"></span>
                        </div>
                    </div>
                    <div class="font-bold text-gray-800 text-sm truncate" title="${run.profile_name}">${run.profile_name}</div>
                    <div class="flex gap-2 mt-2">
                        <span class="text-[10px] bg-slate-100 text-slate-600 px-2 py-0.5 rounded border border-slate-200">Raw: ${run.stats_found || 0}</span>
                        <span class="text-[10px] bg-green-50 text-green-700 px-2 py-0.5 rounded border border-green-200 font-bold">Aprobados: ${run.stats_validated || 0}</span>
                    </div>
                `;
                list.appendChild(btn);

                // Autocargar la primera ejecución disponible en pantalla
                if(index === 0) loadRun(run, btn);
            });
        }

        // Cargar una ejecución específica en el Grafo
        function loadRun(run, btnElement) {
            currentRunData = run;
            
            // Actualizar estilo visual activo de la lista lateral
            document.querySelectorAll('#runs-list button').forEach(b => {
                b.classList.remove('bg-blue-50', 'border-blue-200', 'shadow-sm');
                b.classList.add('bg-white', 'border-gray-100');
            });
            if(btnElement) {
                btnElement.classList.add('bg-blue-50', 'border-blue-200', 'shadow-sm');
                btnElement.classList.remove('bg-white', 'border-gray-100');
            }

            document.getElementById('current-run-title').innerText = `ID: ${run.session_id || run.id.substring(0, 8)}`;
            
            // Deseleccionar nodos previamente marcados en el grafo
            document.querySelectorAll('.node-btn').forEach(n => n.classList.remove('active'));
            document.getElementById('panel-empty').classList.remove('hidden');
            document.getElementById('panel-content').classList.add('hidden');
            
            // Reiniciar panel de inspección lateral
            document.getElementById('panel-title').innerText = 'Inspector de Nodo';
            document.getElementById('panel-role').innerText = 'Selecciona un nodo en el grafo para ver su comportamiento.';
            document.getElementById('panel-icon').innerHTML = '<i class="fa-solid fa-robot"></i>';
            document.getElementById('panel-icon').className = 'w-8 h-8 rounded bg-slate-800 flex items-center justify-center text-lg';
        }

        // Ver inspección del nodo seleccionado
        function selectNode(nodeId) {
            if(!currentRunData || !currentRunData.nodes_data || !currentRunData.nodes_data[nodeId]) {
                alert(`No hay logs registrados para el agente '${nodeId}' en esta ejecución.`);
                return;
            }

            // Cambiar nodo activo en el HTML
            document.querySelectorAll('.node-btn').forEach(n => n.classList.remove('active'));
            document.getElementById(`node-${nodeId}`).classList.add('active');

            const data = currentRunData.nodes_data[nodeId];

            // Configurar estilos visuales del inspector según el nodo/agente
            const titles = {
                orchestrator: { title: 'Orchestrator Agent', icon: 'fa-microchip', color: 'bg-indigo-600' },
                scraper: { title: 'Scraper Agent', icon: 'fa-spider', color: 'bg-emerald-600' },
                matcher: { title: 'Semantic Matcher', icon: 'fa-scale-balanced', color: 'bg-amber-500' },
                reviewer: { title: 'Business Reviewer', icon: 'fa-user-tie', color: 'bg-rose-500' },
                notifier: { title: 'Notification Agent', icon: 'fa-paper-plane', color: 'bg-blue-600' }
            };
            const config = titles[nodeId];

            document.getElementById('panel-title').innerText = config.title;
            document.getElementById('panel-role').innerText = `Misión: ${data.role || 'Procesamiento de datos'}`;
            document.getElementById('panel-icon').innerHTML = `<i class="fa-solid ${config.icon}"></i>`;
            document.getElementById('panel-icon').className = `w-8 h-8 rounded ${config.color} flex items-center justify-center text-lg`;

            // Rellenar contenido con la respuesta del API
            document.getElementById('panel-input').innerHTML = data.input;
            document.getElementById('panel-output').innerHTML = data.output;
            document.getElementById('panel-metrics').innerText = `⏱ ${data.metric || '0s'}`;

            // Listar herramientas
            const toolsContainer = document.getElementById('panel-tools');
            toolsContainer.innerHTML = '';
            
            const toolsArray = data.tools || [];
            if(toolsArray.length === 0) {
                toolsContainer.innerHTML = '<span class="text-xs text-gray-400 italic">Ninguna herramienta externa utilizada.</span>';
            } else {
                toolsArray.forEach(tool => {
                    const badge = document.createElement('span');
                    badge.className = 'bg-slate-200 text-slate-700 text-[10px] font-bold px-2 py-1 rounded border border-slate-300';
                    badge.innerText = tool;
                    toolsContainer.appendChild(badge);
                });
            }

            // Ocultar estado vacío e iniciar animación de entrada del inspector
            document.getElementById('panel-empty').classList.add('hidden');
            const panelContent = document.getElementById('panel-content');
            panelContent.classList.remove('hidden');
            panelContent.classList.remove('fade-in');
            void panelContent.offsetWidth; // Forzar reflow en el navegador para reiniciar animación
            panelContent.classList.add('fade-in');
        }

        // Ejecutar carga de datos al iniciar la ventana
        window.onload = fetchRuns;
